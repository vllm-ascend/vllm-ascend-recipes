---
interface Props {
  label: string;
  color?: 'accent' | 'blue' | 'purple' | 'orange' | 'gray' | 'red';
}

const { label, color = 'gray' } = Astro.props;

const colors: Record<string, string> = {
  accent: 'bg-accent-500/10 text-accent-400 border-accent-500/20',
  blue: 'bg-sky-500/10 text-sky-400 border-sky-500/20',
  purple: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
  orange: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  gray: 'bg-ink-700/40 text-ink-400 border-ink-600/40',
  red: 'bg-red-500/10 text-red-400 border-red-500/20',
};
---

<span
  class={`inline-flex items-center px-2 py-0.5 rounded text-[11px] font-mono font-medium border ${colors[color]}`}
>
  {label}
</span>
