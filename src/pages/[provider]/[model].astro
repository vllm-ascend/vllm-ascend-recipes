---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import MarkdownContent from '../../components/MarkdownContent.astro';
import CascadeSelector from '../../components/CascadeSelector.tsx';
import WeightDownloadTabs from '../../components/WeightDownloadTabs.tsx';
import EnvSetupTabs from '../../components/EnvSetupTabs.tsx';
import { getAllModels, formatContextLength, formatParameters } from '../../lib/models';
import type { Model } from '../../lib/types';

export const getStaticPaths = (async () => {
  const modelsEn = await getAllModels('en');
  const modelsZh = await getAllModels('zh');
  const zhMap = new Map(modelsZh.map(m => [`${m._provider_slug}/${m._model_slug}`, m]));

  return modelsEn.map((modelEn) => {
    const key = `${modelEn._provider_slug}/${modelEn._model_slug}`;
    const modelZh = zhMap.get(key) ?? modelEn;
    return {
      params: { provider: modelEn._provider_slug, model: modelEn._model_slug },
      props: { modelEn, modelZh },
    };
  });
}) satisfies GetStaticPaths;

interface Props { modelEn: Model; modelZh: Model; }

const { modelEn, modelZh } = Astro.props;
const model = modelEn;
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';
const baseSuffix = base.endsWith('/') ? base.slice(0, -1) : base;

const editUrl = `https://github.com/vllm-ascend/vllm-ascend-recipes/edit/main/models/en/${model._provider_slug}/${model._model_slug}.yaml`;
const hasQuantization = !!modelEn.quantization;
const hasPrerequisites = !!modelEn.prerequisites && modelEn.prerequisites.length > 0;
const hasAccuracy = !!modelEn.performance?.accuracy;
const hasBenchmark = !!modelEn.performance?.benchmark;
const hasPerformance = hasAccuracy || hasBenchmark;
const hasVerification = !!modelEn.verification;
const hasTuning = !!modelEn.tuning;
const hasFaq = !!modelEn.faq;
const npus = [...new Set(modelEn.scenarios.map((s) => s.npu))];
const sectionTitle = "font-display text-lg font-semibold text-ink-50 tracking-tight mb-4";

// Build TOC items: each with an anchor id and an i18n key for the label
interface TocItem { id: string; i18n: string }
const tocItems: TocItem[] = [];
function addToc(id: string, i18n: string) { tocItems.push({ id, i18n }); }

addToc('overview', 'sectionOverview');
addToc('weight-download', 'sectionWeightDownload');
if (hasQuantization) addToc('quantization', 'sectionQuantization');
if (hasPrerequisites) addToc('prerequisites', 'sectionPrerequisites');
addToc('env-setup', 'sectionEnvSetup');
addToc('scenarios', 'sectionScenario');
if (hasVerification) addToc('verification', 'sectionVerification');
if (hasPerformance) addToc('performance', 'sectionPerformance');
if (hasTuning) addToc('tuning', 'sectionTuning');
if (hasFaq) addToc('faq', 'sectionFaq');
addToc('references', 'sectionReferences');

function renderDesc(text: string) {
  return `<p>${text}</p>`;
}
---

<BaseLayout title={`${model.title} | vLLM-Ascend Recipes`} description={modelEn.description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex gap-12">
      <!-- TOC sidebar -->
      <aside class="hidden lg:block w-48 shrink-0">
        <nav class="sticky top-20">
          <p class="text-[10px] font-mono uppercase tracking-widest text-ink-600 mb-3">On this page</p>
          <ul class="space-y-0.5 border-l border-ink-800/50">
            {tocItems.map((item) => (
              <li>
                <a
                  href={`#${item.id}`}
                  class="block py-1.5 pl-3 text-xs font-mono text-ink-500 hover:text-accent-400 hover:border-l-2 hover:border-accent-400 -ml-px transition-colors"
                  data-i18n={item.i18n}
                ></a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- Main content -->
      <div class="min-w-0 flex-1">

    <div class="mb-8">
      <div class="flex items-center gap-1.5 text-xs font-mono text-ink-600 mb-4">
        <a href={baseSuffix} class="hover:text-accent-400 transition-colors" data-i18n="home">~</a>
        <span>/</span>
        <a href={`${basePrefix}browse`} class="hover:text-accent-400 transition-colors" data-i18n="navBrowse">browse</a>
        <span>/</span>
        <span class="text-ink-500">{model._provider_slug}</span>
      </div>

      <h1 class="font-display text-3xl font-bold text-ink-50 tracking-tight mb-2">{model.title}</h1>
      <div class="text-sm text-ink-400 max-w-2xl leading-relaxed mb-4">
        <MarkdownContent markdown={modelEn.description} lang="en" />
        <MarkdownContent markdown={modelZh.description} lang="zh" hidden />
      </div>

      <div class="flex flex-wrap gap-2 mb-4">
        <Tag label={model.architecture === 'moe' ? 'MoE' : 'Dense'} color="purple" />
        <Tag label={formatParameters(model.parameters, model.active_parameters)} color="accent" />
        <Tag label={formatContextLength(model.context_length)} color="orange" />
        <Tag label={model.modality} color="gray" />
        {npus.map((npu) => <Tag label={npu} color="blue" />)}
      </div>

      <div class="flex items-center gap-3 text-[11px] font-mono text-ink-600">
        <span><span data-i18n="updated">Updated</span>: {model.updated}</span>
        <span>·</span>
        <a href={editUrl} target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors" data-i18n="editRecipe">
          [ edit ]
        </a>
      </div>
    </div>

    <div class="section-divider"></div>

    <section class="py-8" id="overview">
      <h2 class={sectionTitle} data-i18n="sectionOverview">Overview</h2>
      <MarkdownContent markdown={modelEn.overview} lang="en" />
      <MarkdownContent markdown={modelZh.overview} lang="zh" hidden />
    </section>

    <div class="section-divider"></div>

    <section class="py-8" id="weight-download">
      <h2 class={sectionTitle} data-i18n="sectionWeightDownload">Weight Download</h2>
      <WeightDownloadTabs client:load downloadsEn={modelEn.weight_download} downloadsZh={modelZh.weight_download} />
    </section>

    <div class="section-divider"></div>

    {hasQuantization && (
      <>
        <section class="py-8" id="quantization">
          <h2 class={sectionTitle} data-i18n="sectionQuantization">Quantization</h2>
          <MarkdownContent markdown={modelEn.quantization!.content} lang="en" />
          <MarkdownContent markdown={modelZh.quantization?.content ?? modelEn.quantization!.content} lang="zh" hidden />
        </section>
        <div class="section-divider"></div>
      </>
    )}

    {hasPrerequisites && (
      <>
        <section class="py-8" id="prerequisites">
          <h2 class={sectionTitle} data-i18n="sectionPrerequisites">Prerequisites</h2>
          <div class="space-y-6">
            {modelEn.prerequisites!.map((item, i) => {
              const itemZh = modelZh.prerequisites?.[i] ?? item;
              return (
                <div>
                  <h3 class="lang-en font-display text-base font-semibold text-ink-200 mb-2">{item.title}</h3>
                  <h3 class="lang-zh hidden font-display text-base font-semibold text-ink-200 mb-2">{itemZh.title}</h3>
                  <MarkdownContent markdown={item.content} lang="en" />
                  <MarkdownContent markdown={itemZh.content} lang="zh" hidden />
                </div>
              );
            })}
          </div>
        </section>
        <div class="section-divider"></div>
      </>
    )}

    <section class="py-8" id="env-setup">
      <h2 class={sectionTitle} data-i18n="sectionEnvSetup">Environment Setup</h2>
      <EnvSetupTabs client:load envSetupEn={modelEn.env_setup} envSetupZh={modelZh.env_setup} />
    </section>

    <div class="section-divider"></div>

    <section class="py-8" id="scenarios">
      <h2 class={sectionTitle} data-i18n="sectionScenario">Deployment Scenarios</h2>
      <p class="text-xs text-ink-500 mb-6 font-mono" data-i18n="sectionScenarioDescription">
        Select NPU type, precision, and deployment mode to view the corresponding deployment instructions.
      </p>
      <CascadeSelector client:load scenariosEn={modelEn.scenarios} scenariosZh={modelZh.scenarios} />
    </section>

    <div class="section-divider"></div>

    {hasVerification && (
      <>
        <section class="py-8" id="verification">
          <h2 class={sectionTitle} data-i18n="sectionVerification">Verification</h2>
          <MarkdownContent markdown={modelEn.verification!} lang="en" />
          <MarkdownContent markdown={modelZh.verification ?? modelEn.verification!} lang="zh" hidden />
        </section>
        <div class="section-divider"></div>
      </>
    )}

    {hasPerformance && (
      <>
        <section class="py-8" id="performance">
          <h2 class={sectionTitle} data-i18n="sectionPerformance">Performance</h2>
          <div class="space-y-8">
            {hasAccuracy && (
              <div>
                <h3 class="font-display text-base font-semibold text-ink-200 mb-3" data-i18n="sectionAccuracy">Accuracy</h3>
                <MarkdownContent markdown={modelEn.performance!.accuracy!} lang="en" />
                <MarkdownContent markdown={modelZh.performance?.accuracy ?? modelEn.performance!.accuracy!} lang="zh" hidden />
              </div>
            )}
            {hasBenchmark && (
              <div>
                <h3 class="font-display text-base font-semibold text-ink-200 mb-3" data-i18n="sectionBenchmark">Benchmark</h3>
                <MarkdownContent markdown={modelEn.performance!.benchmark!} lang="en" />
                <MarkdownContent markdown={modelZh.performance?.benchmark ?? modelEn.performance!.benchmark!} lang="zh" hidden />
              </div>
            )}
          </div>
        </section>
        <div class="section-divider"></div>
      </>
    )}

    {hasTuning && (
      <>
        <section class="py-8" id="tuning">
          <h2 class={sectionTitle} data-i18n="sectionTuning">Performance Tuning</h2>
          <MarkdownContent markdown={modelEn.tuning!} lang="en" />
          <MarkdownContent markdown={modelZh.tuning ?? modelEn.tuning!} lang="zh" hidden />
        </section>
        <div class="section-divider"></div>
      </>
    )}

    {hasFaq && (
      <>
        <section class="py-8" id="faq">
          <h2 class={sectionTitle} data-i18n="sectionFaq">FAQ</h2>
          <MarkdownContent markdown={modelEn.faq!} lang="en" />
          <MarkdownContent markdown={modelZh.faq ?? modelEn.faq!} lang="zh" hidden />
        </section>
        <div class="section-divider"></div>
      </>
    )}

    <section class="py-8" id="references">
      <h2 class={sectionTitle} data-i18n="sectionReferences">References</h2>
      <ul class="space-y-1.5">
        {modelEn.references.map((ref) => (
          <li>
            <a href={ref.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors font-mono">
              <span class="text-ink-600">→</span>
              {ref.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

      </div>
      {/* end main content */}
    </div>
    {/* end flex container */}
  </div>

  <script>
    // Scroll spy: highlight active TOC link
    const tocLinks = document.querySelectorAll('aside nav a[href^="#"]');
    const sections = [...tocLinks].map(a => document.querySelector(a.getAttribute('href')));

    function updateActiveLink() {
      let currentId = '';
      for (const section of sections) {
        if (!section) continue;
        const rect = section.getBoundingClientRect();
        if (rect.top <= 120) {
          currentId = section.id;
        }
      }
      for (const link of tocLinks) {
        const isActive = link.getAttribute('href') === '#' + currentId;
        link.classList.toggle('!text-accent-400', isActive);
        link.classList.toggle('!border-accent-400', isActive);
        link.classList.toggle('border-l-2', isActive);
      }
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateActiveLink(); ticking = false; });
        ticking = true;
      }
    });
    updateActiveLink();
  </script>
</BaseLayout>
