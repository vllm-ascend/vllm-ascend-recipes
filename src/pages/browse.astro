---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.tsx';
import { getModelList, getProviders } from '../lib/models';

const modelsEn = await getModelList('en');
const modelsZh = await getModelList('zh');
const providers = await getProviders('en');
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';

const enWithBase = modelsEn.map((m) => ({
  ...m,
  url: `${basePrefix}${m.url.replace(/^\//, '')}`,
  json: `${basePrefix}${m.json.replace(/^\//, '')}`,
}));

const zhWithBase = modelsZh.map((m) => ({
  ...m,
  url: `${basePrefix}${m.url.replace(/^\//, '')}`,
  json: `${basePrefix}${m.json.replace(/^\//, '')}`,
}));

// Group models by provider for the sidebar
const providerMap = new Map<
  string,
  { name: string; slug: string; models: { title: string; slug: string; url: string }[] }
>();
for (const p of providers) {
  providerMap.set(p.slug, { name: p.name, slug: p.slug, models: [] });
}
for (const m of modelsEn) {
  const parts = m.url.split('/').filter(Boolean);
  const providerSlug = parts[0];
  const modelSlug = parts[1];
  const entry = providerMap.get(providerSlug);
  if (entry) {
    entry.models.push({
      title: m.title,
      slug: modelSlug,
      url: `${basePrefix}${providerSlug}/${modelSlug}`,
    });
  }
}
const providerGroups = Array.from(providerMap.values());
---

<BaseLayout title="Browse | vLLM-Ascend Recipes">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex gap-8">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-56 flex-shrink-0">
        <div class="sticky top-20">
          <h2
            class="font-display text-xs font-semibold uppercase tracking-wider text-ink-600 mb-3 px-2"
            data-i18n="browseByProvider"
          >
            Providers
          </h2>
          <nav class="space-y-1">
            {
              providerGroups.map((group) => (
                <div class="mb-3">
                  <a
                    href={`${basePrefix}browse`}
                    class="flex items-center justify-between px-2 py-1.5 rounded-md text-sm font-medium text-ink-300 hover:text-accent-400 hover:bg-accent-500/5 transition-colors"
                  >
                    <span>{group.name}</span>
                    <span class="text-[10px] font-mono text-ink-600">{group.models.length}</span>
                  </a>
                  <ul class="ml-2 mt-0.5 space-y-0.5 border-l border-ink-800/60 pl-2">
                    {group.models.map((m) => (
                      <li>
                        <a
                          href={m.url}
                          class="block px-2 py-1 rounded text-xs text-ink-500 hover:text-accent-400 hover:bg-accent-500/5 transition-colors truncate"
                        >
                          {m.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </nav>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-2">
            <h1
              class="font-display text-2xl font-bold text-ink-50 tracking-tight"
              data-i18n="browseTitle"
            >
              Browse all recipes
            </h1>
            <span class="font-mono text-xs text-ink-600">[ {modelsEn.length} total ]</span>
          </div>
          <p class="text-sm text-ink-500" data-i18n="browseDescription">
            Filter by NPU type, architecture, modality, or search by model name.
          </p>
        </div>

        <SearchBar client:load modelsEn={enWithBase} modelsZh={zhWithBase} />
      </div>
    </div>
  </div>
</BaseLayout>
