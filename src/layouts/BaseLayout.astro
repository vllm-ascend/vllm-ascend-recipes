---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle';
import LanguageToggle from '../components/LanguageToggle';
import { translations } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = translations.en.siteTitle,
  description = translations.en.siteDescription,
} = Astro.props;

const baseUrl = 'https://vllm-ascend.github.io/vllm-ascend-recipes';
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';
const baseSuffix = base.endsWith('/') ? base.slice(0, -1) : base;
---

<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={baseUrl} />
    <link rel="icon" type="image/svg+xml" href={`${basePrefix}favicon.svg`} />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      const savedLang = localStorage.getItem('lang');
      if (savedLang) {
        document.documentElement.lang = savedLang;
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col relative">
    <div class="fixed inset-0 grid-pattern pointer-events-none" style="z-index:0"></div>

    <header class="sticky top-0 z-50 border-b border-ink-800/50 backdrop-blur-xl bg-ink-950/70 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="h-14 flex items-center justify-between">
          <a href={baseSuffix} class="flex items-center gap-2.5 group">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-accent-500/10 border border-accent-500/20 text-accent-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <rect x="6" y="6" width="12" height="12" rx="2" />
                <path d="M9 2v2M12 2v2M15 2v2M9 20v2M12 20v2M15 20v2M2 9h2M2 12h2M2 15h2M20 9h2M20 12h2M20 15h2" stroke-linecap="round" />
              </svg>
            </span>
            <span class="font-display font-semibold text-sm tracking-tight text-ink-100 group-hover:text-accent-300 transition-colors">
              vllm-ascend<span class="text-ink-600">/</span><span class="text-accent-400">recipes</span>
            </span>
          </a>
          <nav class="flex items-center gap-1 sm:gap-2">
            <a href={`${basePrefix}browse`} class="px-3 py-1.5 text-xs font-medium text-ink-400 hover:text-accent-400 transition-colors rounded-md hover:bg-accent-500/5" data-i18n="navBrowse">Browse</a>
            <a href="https://docs.vllm.ai/projects/ascend/" target="_blank" rel="noopener" class="px-3 py-1.5 text-xs font-medium text-ink-400 hover:text-accent-400 transition-colors rounded-md hover:bg-accent-500/5" data-i18n="navDocs">Docs</a>
            <a href="https://github.com/vllm-project/vllm-ascend" target="_blank" rel="noopener" class="px-3 py-1.5 text-xs font-medium text-ink-400 hover:text-accent-400 transition-colors rounded-md hover:bg-accent-500/5">GitHub</a>
            <a href={`${basePrefix}models.json`} class="px-3 py-1.5 text-xs font-mono text-ink-500 hover:text-accent-400 transition-colors rounded-md hover:bg-accent-500/5">.json</a>
            <div class="w-px h-5 bg-ink-800 mx-1"></div>
            <LanguageToggle client:load />
            <ThemeToggle client:load />
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1 relative" style="z-index:2">
      <slot />
    </main>

    <footer class="relative border-t border-ink-800/50 mt-20" style="z-index:2">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-2 text-xs text-ink-500 font-mono">
            <svg class="w-3 h-3 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <rect x="6" y="6" width="12" height="12" rx="2" />
              <path d="M9 2v2M12 2v2M15 2v2M9 20v2M12 20v2M15 20v2M2 9h2M2 12h2M2 15h2M20 9h2M20 12h2M20 15h2" stroke-linecap="round" />
            </svg>
            <span data-i18n="footerText">Community-maintained vllm-ascend deployment recipes</span>
          </div>
          <a href={`https://github.com/vllm-ascend/vllm-ascend-recipes/edit/main/models/`} target="_blank" rel="noopener" class="text-xs font-mono text-ink-500 hover:text-accent-400 transition-colors" data-i18n="contribute">
            [ contribute ]
          </a>
        </div>
      </div>
    </footer>

    <script is:inline define:vars={{ translations }}>
      function applyLang(lang) {
        const dict = translations[lang] || translations.en;
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && Object.prototype.hasOwnProperty.call(dict, key)) {
            el.textContent = dict[key];
          }
        });
      }

      const savedLang = localStorage.getItem('lang') || 'en';
      applyLang(savedLang);

      window.addEventListener('langchange', (e) => {
        applyLang(e.detail);
      });
    </script>
  </body>
</html>
